# .gitignore — 词元智算 / Muse 复刻项目

# ===== 依赖与构建产物 =====
node_modules/
dist/
build/
.output/
.next/
.vite/
.cache/
coverage/
*.tsbuildinfo

# ===== 密钥 / 环境变量 / 本地配置 =====
.env
.env.*
.env.example
*.local
secrets.json
config.local.*
credentials.*

# ===== 本地数据（本地优先·零后端产物） =====
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/
server/data/
/local/

# ===== 日志与临时文件 =====
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# ===== 编辑器 / IDE =====
.vscode/
.idea/
*.swp

# ===== 大体积资源 =====
*.mp4
*.mov
*.png.orig
*.psd
weights/
models/

# ===== Agent / 工具目录 =====
.codebuddy/
.vercel
